# ============================================
# Flytify — Environment Configuration
# ============================================
# Copy this file to .env (same folder):
#
#   cp .env.example .env
#
# Then fill in your database details below.
#
# IMPORTANT: .env contains passwords. It is
# listed in .gitignore and will NOT be committed
# to GitHub. Only .env.example is shared.
# If you accidentally commit .env, CHANGE YOUR
# PASSWORD IMMEDIATELY.
# ============================================

DB_HOST=localhost
DB_NAME=flytify
DB_USER=root
DB_PASS=
